####################################################
# DATABASE
####################################################

DATABASE_URL=postgresql://user:password@localhost:5432/doc_extraction_db

####################################################
# AI PROVIDER
####################################################

GEMINI_API_KEY=your_gemini_api_key_here

####################################################
# SECURITY
####################################################

# Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"

API_KEY_HASH_SECRET=your_strong_random_secret_here

####################################################
# APPLICATION
####################################################

APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=10

####################################################
# WUZAPI CLIENT (API -> WUZAPI)
####################################################

WUZAPI_BASE_URL=http://wuzapi:8080
WUZAPI_INSTANCE=your_instance_name
WUZAPI_TOKEN=your_wuzapi_token
WUZAPI_APPLICATION_ID=00000000-0000-0000-0000-000000000000

####################################################
# WUZAPI SERVER
####################################################

WUZAPI_ADMIN_TOKEN=your_strong_random_password_here
WUZAPI_PORT=8080
SESSION_DEVICE_NAME=API Transcrição IA
TZ=America/Sao_Paulo
