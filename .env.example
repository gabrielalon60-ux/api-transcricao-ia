# Database
DATABASE_URL=postgresql://user:password@localhost:5432/doc_extraction_db

# AI Provider
GEMINI_API_KEY=your_gemini_api_key_here

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY_HASH_SECRET=your_strong_random_secret_here
MAX_UPLOAD_SIZE_MB=10

# App Settings
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO

# WhatsApp / WUZAPI Integration
WUZAPI_BASE_URL=http://localhost:8080
WUZAPI_INSTANCE=your_instance_name
WUZAPI_TOKEN=your_wuzapi_token
# UUID of the Application row in the DB attributed to WhatsApp requests
# Run: INSERT INTO applications (id, name, api_key_hash, active) VALUES (...)
WUZAPI_APPLICATION_ID=00000000-0000-0000-0000-000000000000

